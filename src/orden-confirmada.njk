---
layout: checkout-layout.njk
titulo: "¡Pedido recibido!"
---

<section style="max-width: 520px; margin: 0 auto; padding: 3rem 1rem 4rem; text-align: center;">

  <div id="confirm-content" style="display:none;">

    <!-- Ícono -->
    <div style="font-size:5rem; margin-bottom:1.5rem; animation:confirm-bounce .6s ease;">✅</div>

    <!-- Título -->
    <h1 style="font-size:1.75rem; font-weight:800; color:#fff; margin-bottom:0.75rem;">
      ¡Pedido recibido!
    </h1>

    <!-- Mensaje entrega -->
    <div id="confirm-msg-entrega" style="color:rgba(255,255,255,0.6); margin-bottom:2rem; line-height:1.7; font-size:0.95rem;">
      Hemos recibido tu pedido correctamente.<br>
      Te contactaremos pronto para coordinar la entrega.
    </div>

    <!-- Mensaje transferencia -->
    <div id="confirm-msg-transferencia" style="display:none; margin-bottom:2rem;">
      <div style="background:rgba(251,191,36,0.08); border:1.5px solid rgba(251,191,36,0.3); border-radius:1rem; padding:1.25rem; text-align:left;">
        <p style="margin:0 0 0.5rem; font-size:1rem; font-weight:800; color:#fbbf24;">⚠️ Último paso importante</p>
        <p style="margin:0; color:rgba(255,255,255,0.7); font-size:0.875rem; line-height:1.65;">
          Solicita los números de cuenta por WhatsApp para agilizar el envío de tu pedido, o espera a que te contactemos al número de teléfono que nos brindaste.
        </p>
      </div>
    </div>

    <!-- Resumen del pedido -->
    <div id="confirm-resumen" style="background:#171717; border:1px solid rgba(255,255,255,0.08); border-radius:1rem; padding:1.25rem; margin-bottom:2rem; text-align:left;">
      <p id="confirm-cliente" style="margin:0 0 0.5rem; font-size:0.85rem; color:rgba(255,255,255,0.5);"></p>
      <p id="confirm-total-txt" style="margin:0; font-size:1.1rem; font-weight:700; color:#fff;"></p>
    </div>

    <!-- Botón WhatsApp -->
    <div style="margin-bottom:1rem; position:relative;">
      <span id="confirm-wa-pulse" style="position:absolute;inset:0;border-radius:0.875rem;background:#25D366;animation:whatsapp-pulse 2s ease-out infinite;z-index:0;pointer-events:none;display:none;"></span>
      <a id="confirm-whatsapp" href="#" target="_blank" rel="noopener"
        style="display:flex;align-items:center;justify-content:center;gap:0.6rem;padding:0.875rem;background:#25D366;color:#fff;border-radius:0.875rem;text-decoration:none;font-size:0.95rem;font-weight:700;width:100%;box-shadow:0 4px 20px rgba(37,211,102,0.4);transition:transform .2s ease, box-shadow .2s ease;position:relative;z-index:1;"
        onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 28px rgba(37,211,102,0.55)'"
        onmouseout="this.style.transform='none';this.style.boxShadow='0 4px 20px rgba(37,211,102,0.4)'">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span id="confirm-whatsapp-label">Confirmar por WhatsApp</span>
      </a>
    </div>

    <!-- Botón seguir comprando -->
    <a href="/" class="btn btn-outline-secondary w-100" style="border-radius:0.75rem;">
      Seguir comprando
    </a>

  </div>

  <!-- Si llega sin pedido en sessionStorage -->
  <div id="confirm-empty" style="display:none;">
    <div style="font-size:3rem; margin-bottom:1rem;">🤔</div>
    <p style="color:rgba(255,255,255,0.6);">No encontramos un pedido activo.</p>
    <a href="/" class="btn btn-primary mt-3">Ir al inicio</a>
  </div>

</section>

<style>
  @keyframes confirm-bounce {
    0%   { transform: scale(0.5); opacity: 0; }
    70%  { transform: scale(1.1); }
    100% { transform: scale(1);   opacity: 1; }
  }
  @keyframes whatsapp-pulse {
    0%   { opacity: 0.6; transform: scale(1); }
    100% { opacity: 0;   transform: scale(1.5); }
  }
</style>

<script>
  (function() {
    const WA_NUMBER = '50234646667';

    // Leer datos del pedido desde sessionStorage
    const raw = sessionStorage.getItem('arms-pedido');

    if (!raw) {
      document.getElementById('confirm-empty').style.display = 'block';
      return;
    }

    let pedido;
    try { pedido = JSON.parse(raw); } catch(e) {
      document.getElementById('confirm-empty').style.display = 'block';
      return;
    }

    // Verificar que no sea un pedido muy viejo (más de 1 hora)
    if (pedido.timestamp && Date.now() - pedido.timestamp > 3600000) {
      sessionStorage.removeItem('arms-pedido');
      document.getElementById('confirm-empty').style.display = 'block';
      return;
    }

    // Mostrar contenido
    document.getElementById('confirm-content').style.display = 'block';

    // Datos del cliente
    document.getElementById('confirm-cliente').textContent = `Pedido de ${pedido.nombre} · ${pedido.pago}`;
    document.getElementById('confirm-total-txt').textContent = `Total: ${pedido.total}`;

    // WhatsApp
    document.getElementById('confirm-whatsapp').href = pedido.waURL;

    // Mensaje según forma de pago
    if (pedido.esTransferencia) {
      document.getElementById('confirm-msg-entrega').style.display      = 'none';
      document.getElementById('confirm-msg-transferencia').style.display = 'block';
      document.getElementById('confirm-whatsapp-label').textContent      = 'Solicitar Cuenta por WhatsApp';
      const pulse = document.getElementById('confirm-wa-pulse');
      pulse.style.display = 'block';
    }

    // Limpiar sessionStorage después de mostrar
    sessionStorage.removeItem('arms-pedido');

    // ── FACEBOOK PIXEL — evento Purchase ──────────────────────
    if (typeof fbq === 'function') {
      try {
        const totalNum = parseFloat(pedido.total.replace('Q', '').replace(',', ''));
        fbq('track', 'Purchase', {
          value:    isNaN(totalNum) ? 0 : totalNum,
          currency: 'GTQ'
        });
      } catch(e) {}
    }

  })();
</script>
