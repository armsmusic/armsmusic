---
layout: checkout-layout.njk
titulo: "Finalizar pedido"
incluirCheckoutJS: true
---

<section style="max-width: 960px; margin: 0 auto; padding: 2rem 1rem 4rem;">

  <div class="row g-4 align-items-start">

    <!-- ── COLUMNA IZQUIERDA: Formulario ── -->
    <div class="col-12 col-lg-7">

      <h1 style="font-size: 1.5rem; font-weight: 800; color: #fff; margin-bottom: 1.75rem;">
        📋 Datos de entrega
      </h1>

      <!-- Honeypot anti-spam (oculto) -->
      <div style="display:none;" aria-hidden="true">
        <input type="text" id="f-website" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <div style="display: flex; flex-direction: column; gap: 1rem;">

        <!-- Nombre -->
        <div>
          <label for="f-nombre" style="font-size:0.85rem; color:rgba(255,255,255,0.6); margin-bottom:0.4rem; display:block;">
            Nombre completo *
          </label>
          <input id="f-nombre" type="text" placeholder="Nombre de quien recibe"
            style="width:100%; padding:0.75rem 1rem; background:#212121; border:1px solid rgba(255,255,255,0.1); border-radius:0.75rem; color:#fff; font-family:inherit; font-size:0.95rem; outline:none;" />
        </div>

        <!-- Teléfono -->
        <div>
          <label for="f-telefono" style="font-size:0.85rem; color:rgba(255,255,255,0.6); margin-bottom:0.4rem; display:block;">
            Teléfono *
          </label>
          <div id="error-telefono" style="display:none; color:#f87171; font-size:0.8rem; margin-bottom:0.4rem;">
            ⚠️ El teléfono debe tener exactamente 8 dígitos.
          </div>
          <input id="f-telefono" type="tel" placeholder="5555-1234"
            oninput="limpiarErrorTelefono()"
            style="width:100%; padding:0.75rem 1rem; background:#212121; border:1px solid rgba(255,255,255,0.1); border-radius:0.75rem; color:#fff; font-family:inherit; font-size:0.95rem; outline:none; transition:border-color .2s ease;" />
        </div>

        <!-- Dirección -->
        <div>
          <label for="f-direccion" style="font-size:0.85rem; color:rgba(255,255,255,0.6); margin-bottom:0.4rem; display:block;">
            Dirección de entrega *
          </label>
          <input id="f-direccion" type="text" placeholder="Calle, zona, avenida, aldea, colonia, etc."
            style="width:100%; padding:0.75rem 1rem; background:#212121; border:1px solid rgba(255,255,255,0.1); border-radius:0.75rem; color:#fff; font-family:inherit; font-size:0.95rem; outline:none;" />
        </div>

        <!-- Departamento -->
        <div>
          <label for="f-departamento" style="font-size:0.85rem; color:rgba(255,255,255,0.6); margin-bottom:0.4rem; display:block;">
            Departamento *
          </label>
          <select id="f-departamento" onchange="actualizarMunicipios()"
            style="width:100%; padding:0.75rem 1rem; background:#212121; border:1px solid rgba(255,255,255,0.1); border-radius:0.75rem; color:#fff; font-family:inherit; font-size:0.95rem; outline:none; appearance:none; -webkit-appearance:none; cursor:pointer; background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22rgba(255,255,255,0.4)%22 stroke-width=%222%22><polyline points=%226 9 12 15 18 9%22/></svg>'); background-repeat:no-repeat; background-position:right 1rem center;">
            <option value="" disabled selected>Selecciona un departamento</option>
            <option>Alta Verapaz</option><option>Baja Verapaz</option><option>Chimaltenango</option>
            <option>Chiquimula</option><option>El Progreso</option><option>Escuintla</option>
            <option>Guatemala</option><option>Huehuetenango</option><option>Izabal</option>
            <option>Jalapa</option><option>Jutiapa</option><option>Petén</option>
            <option>Quetzaltenango</option><option>Quiché</option><option>Retalhuleu</option>
            <option>Sacatepéquez</option><option>San Marcos</option><option>Santa Rosa</option>
            <option>Sololá</option><option>Suchitepéquez</option><option>Totonicapán</option>
            <option>Zacapa</option>
          </select>
        </div>

        <!-- Municipio -->
        <div>
          <label for="f-municipio" style="font-size:0.85rem; color:rgba(255,255,255,0.6); margin-bottom:0.4rem; display:block;">
            Municipio *
          </label>
          <select id="f-municipio" onchange="scrollAFormaPago()"
            style="width:100%; padding:0.75rem 1rem; background:#212121; border:1px solid rgba(255,255,255,0.1); border-radius:0.75rem; color:#fff; font-family:inherit; font-size:0.95rem; outline:none; appearance:none; -webkit-appearance:none; cursor:pointer; background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22rgba(255,255,255,0.4)%22 stroke-width=%222%22><polyline points=%226 9 12 15 18 9%22/></svg>'); background-repeat:no-repeat; background-position:right 1rem center;">
            <option value="" disabled selected>Primero selecciona un departamento</option>
          </select>
        </div>

        <!-- Notas -->
        <div>
          <label for="f-notas" style="font-size:0.85rem; color:rgba(255,255,255,0.6); margin-bottom:0.4rem; display:block;">
            Notas adicionales
          </label>
          <textarea id="f-notas" placeholder="Referencias, instrucciones especiales..." rows="3"
            style="width:100%; padding:0.75rem 1rem; background:#212121; border:1px solid rgba(255,255,255,0.1); border-radius:0.75rem; color:#fff; font-family:inherit; font-size:0.95rem; outline:none; resize:none;"></textarea>
        </div>

        <!-- Forma de pago -->
        <div>
          <label id="forma-pago-label" style="font-size:0.85rem; color:rgba(255,255,255,0.6); margin-bottom:0.75rem; display:block; text-transform:uppercase; letter-spacing:0.06em; font-weight:700;">
            Forma de pago *
          </label>
          <div style="display:flex; flex-direction:column; gap:0.5rem;">

            <label id="lbl-pago-entrega" onclick="seleccionarPago('entrega')"
              style="display:flex;align-items:center;gap:0.85rem;background:rgba(16,185,129,0.12);border:1.5px solid #10B981;border-radius:0.75rem;padding:0.875rem 1rem;cursor:pointer;transition:all .2s ease;">
              <span style="font-size:1.4rem;flex-shrink:0;">🚚</span>
              <div style="flex:1;">
                <p style="margin:0;font-weight:600;color:#10B981;font-size:0.9rem;">Pago Contra Entrega</p>
                <p style="margin:0;color:rgba(255,255,255,0.45);font-size:0.78rem;">Pagas cuando recibes tu pedido</p>
              </div>
              <span id="radio-entrega" style="width:18px;height:18px;border-radius:50%;flex-shrink:0;border:2px solid #10B981;background:#10B981;display:flex;align-items:center;justify-content:center;">
                <span style="width:7px;height:7px;border-radius:50%;background:#fff;"></span>
              </span>
            </label>

            <label id="lbl-pago-transferencia" onclick="seleccionarPago('transferencia')"
              style="display:flex;align-items:center;gap:0.85rem;background:rgba(255,255,255,0.03);border:1.5px solid rgba(255,255,255,0.1);border-radius:0.75rem;padding:0.875rem 1rem;cursor:pointer;transition:all .2s ease;">
              <span style="font-size:1.4rem;flex-shrink:0;">🏦</span>
              <div style="flex:1;">
                <p style="margin:0;font-weight:600;color:#fff;font-size:0.9rem;">Transferencia / Depósito</p>
                <p id="subtitulo-transferencia" style="margin:0;color:rgba(255,255,255,0.45);font-size:0.78rem;">Depósito o transferencia bancaria</p>
              </div>
              <span id="radio-transferencia" style="width:18px;height:18px;border-radius:50%;flex-shrink:0;border:2px solid rgba(255,255,255,0.25);background:transparent;"></span>
            </label>

            <label style="display:flex;align-items:center;gap:0.85rem;background:rgba(255,255,255,0.02);border:1.5px solid rgba(255,255,255,0.06);border-radius:0.75rem;padding:0.875rem 1rem;cursor:not-allowed;opacity:0.45;">
              <span style="font-size:1.4rem;flex-shrink:0;">💳</span>
              <div style="flex:1;">
                <p style="margin:0;font-weight:600;color:#fff;font-size:0.9rem;">Tarjeta de Débito / Crédito</p>
                <p style="margin:0;color:rgba(255,255,255,0.45);font-size:0.78rem;">(Próximamente)</p>
              </div>
            </label>

          </div>
        </div>

        <!-- Error -->
        <div id="form-error" style="display:none; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); border-radius:0.75rem; padding:0.75rem 1rem; color:#f87171; font-size:0.875rem;"></div>

        <!-- Botón enviar -->
        <button id="btn-enviar" onclick="enviarPedido()"
          class="btn btn-primary w-100"
          style="border-radius:0.75rem; padding:0.875rem; font-size:1rem; font-weight:700; margin-top:0.5rem;">
          ✅ Confirmar pedido
        </button>

      </div>
    </div>

    <!-- ── COLUMNA DERECHA: Resumen (sticky en desktop) ── -->
    <div class="col-12 col-lg-5">
      <div style="background:#171717; border:1px solid rgba(255,255,255,0.08); border-radius:1rem; padding:1.5rem; position:sticky; top:1.5rem;">
        <h2 style="font-size:1rem; font-weight:700; color:#fff; margin-bottom:1.25rem; text-transform:uppercase; letter-spacing:0.06em;">
          🛒 Resumen del pedido
        </h2>
        <div id="checkout-summary" style="display:flex; flex-direction:column; gap:0.75rem; margin-bottom:1.25rem;"></div>
        <div style="border-top:1px solid rgba(255,255,255,0.08); padding-top:1rem; display:flex; justify-content:space-between; align-items:center;">
          <span style="color:rgba(255,255,255,0.6); font-size:0.95rem;">Total</span>
          <span id="checkout-total" style="font-size:1.4rem; font-weight:800; color:#fff;"></span>
        </div>
        <p style="margin-top:0.75rem; font-size:0.78rem; color:rgba(255,255,255,0.35); text-align:center;">
          Envío calculado según tu departamento
        </p>
      </div>
    </div>

  </div>

</section>

<!-- Overlay de progreso -->
<div id="progress-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:9999; flex-direction:column; align-items:center; justify-content:center; padding:2rem; text-align:center;">
  <div id="progress-spinner" style="font-size:4rem; margin-bottom:2rem; animation:spin-icon 1.5s linear infinite; display:inline-block;">📦</div>
  <h4 id="progress-title" style="color:#fff; font-weight:800; font-size:1.4rem; margin-bottom:0.4rem; min-height:2rem; transition:opacity .3s ease;">Colocando tu pedido...</h4>
  <p id="progress-sub" style="color:rgba(255,255,255,0.45); font-size:0.85rem; margin-bottom:2.5rem; min-height:1.2rem; transition:opacity .3s ease;">Registrando tu orden</p>
  <div style="width:100%; max-width:320px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
      <span style="font-size:0.75rem; color:rgba(255,255,255,0.4); font-weight:500;">Progreso</span>
      <span id="progress-pct" style="font-size:0.85rem; color:#6600FF; font-weight:700;">0%</span>
    </div>
    <div style="height:6px; background:rgba(255,255,255,0.08); border-radius:99px; overflow:hidden;">
      <div id="progress-bar-fill" style="height:100%; width:0%; border-radius:99px; background:linear-gradient(90deg,#6600FF,#10B981); transition:width 1.2s cubic-bezier(0.4,0,0.2,1);"></div>
    </div>
  </div>
</div>

<style>
  /* Item del resumen */
  .checkout-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .checkout-item-img {
    width: 48px;
    height: 48px;
    min-width: 48px;
    border-radius: 0.5rem;
    overflow: hidden;
    background: rgba(255,255,255,0.05);
  }
  .checkout-item-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .checkout-item-info {
    flex: 1;
    min-width: 0;
  }
  .checkout-item-nombre {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
    line-height: 1.3;
    word-break: break-word;
  }
  .checkout-item-qty {
    margin: 0;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.4);
  }
  .checkout-item-precio {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
  }
</style>
