---
layout: base.njk
titulo: "Buscar Productos"
seoTitulo: "Buscar | ARMS Music Guatemala"
seoDescripcion: "Busca entre todos los productos de ARMS Music Guatemala."
permalink: /buscar/
robots: "noindex, nofollow"
---

<section>
  <div class="container">

    <h1 id="buscar-titulo" class="mb-4">Buscar productos</h1>

    <!-- Input de búsqueda -->
    <div style="position:relative; max-width:560px; margin-bottom:1.5rem;">
      <svg style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:rgba(255,255,255,0.35);pointer-events:none;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input
        id="buscar-input"
        type="search"
        placeholder="Buscar producto..."
        autocomplete="off" autocorrect="off" spellcheck="false"
        aria-label="Buscar productos"
        style="width:100%; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); border-radius:2rem; padding:0.65rem 1.25rem 0.65rem 2.75rem; color:#fff; font-family:'Lexend',sans-serif; font-size:0.95rem; outline:none; -webkit-appearance:none; transition:border-color .2s;"
        onfocus="this.style.borderColor='rgba(102,0,255,0.5)'"
        onblur="this.style.borderColor='rgba(255,255,255,0.12)'"
      />
    </div>

    <!-- Filtro de precio -->
    <div style="max-width:560px; margin-bottom:2rem; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:1rem; padding:1rem 1.25rem;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.75rem;">
        <span id="buscar-lbl-rango" style="font-size:0.875rem; color:rgba(255,255,255,0.6);">Todos los precios</span>
        <button id="buscar-precio-reset" style="display:none; background:none; border:none; color:rgba(102,0,255,0.8); font-size:0.8rem; font-weight:600; cursor:pointer; padding:0; font-family:inherit;">Limpiar</button>
      </div>
      <div class="slider-dual-wrap">
        <div class="slider-track-bg"></div>
        <div class="slider-track-fill" id="buscar-track-fill"></div>
        <input type="range" id="buscar-range-min" min="0" max="2000" value="0" step="25" />
        <input type="range" id="buscar-range-max" min="0" max="2000" value="2000" step="25" />
      </div>
      <div style="display:flex; justify-content:space-between; margin-top:0.4rem;">
        <span style="font-size:0.75rem; color:rgba(255,255,255,0.4);">Q<span id="buscar-lbl-min">0</span></span>
        <span style="font-size:0.75rem; color:rgba(255,255,255,0.4);">Q<span id="buscar-lbl-max">2000</span></span>
      </div>
    </div>

    <!-- Contador de resultados -->
    <p id="buscar-count" style="font-size:0.875rem; color:rgba(255,255,255,0.4); margin-bottom:1rem;"></p>

    <!-- Resultados -->
    <div id="buscar-resultados">
      <p style="color:rgba(255,255,255,0.4); text-align:center; padding:3rem 1rem;">Cargando productos...</p>
    </div>

  </div>
</section>
