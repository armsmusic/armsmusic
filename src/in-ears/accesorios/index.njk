---
layout: base.njk
titulo: Accesorios In-Ears KZ — ARMS Music Guatemala
meta_description: Cables, tips, estuches y accesorios para audífonos KZ y QKZ en Guatemala. 11 productos disponibles. Envío a toda Guatemala con ARMS Music.
permalink: /in-ears/accesorios/index.html
---

<div class="categoria-page">

  <!-- HERO DE CATEGORÍA -->
  <section class="categoria-hero">
    <div class="container">
      <nav aria-label="Ruta de navegación" style="margin-bottom:1rem;">
        <ol class="breadcrumb-arms">
          <li><a href="/">Inicio</a></li>
          <li><span aria-hidden="true">›</span></li>
          <li><a href="/in-ears/">In-Ears</a></li>
          <li><span aria-hidden="true">›</span></li>
          <li aria-current="page">Accesorios</li>
        </ol>
      </nav>
      <div class="categoria-hero-inner">
        <div>
          <h1 class="categoria-titulo">Accesorios In-Ears</h1>
          <p class="categoria-subtitulo">Cables, tips, estuches y más para tus audífonos KZ y QKZ</p>
        </div>
        <div class="categoria-stats">
          <span class="categoria-count">{{ productos["accesorios-inears"] | length }} productos</span>
        </div>
      </div>
      <!-- Banner volver a in-ears -->
      <a href="/in-ears/" class="categoria-banner-accesorio">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        <span>Ver todos los <strong>In-Ears KZ y QKZ</strong></span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
  </section>

  <!-- GRID DE PRODUCTOS -->
  <section class="categoria-grid-section">
    <div class="container">

      <div class="row g-3" id="row-categoria-accesorios">
        {% for prod in productos["accesorios-inears"] %}
        {% set varId = ("var-cat-" + prod.nombre) | replace(" ", "-") | replace("/", "-") %}
        {% set btnId = ("btn-cat-" + prod.nombre) | replace(" ", "-") | replace("/", "-") %}
        {% set prodUrl = prod.id | productoUrl %}
        <div class="col-6 col-lg-3">
            {% include "card-producto.njk" %}
        </div>
        {% endfor %}
      </div>

    </div>
  </section>

</div>
