---
layout: base.njk
titulo: Interfaces de Audio — ARMS Music Guatemala
meta_description: Interfaces de audio profesional en Guatemala. Joyo, iRig y más para grabación y producción. Envío a toda Guatemala con ARMS Music.
permalink: /audio/interfaces/index.html
---

<div class="categoria-page">

  <!-- HERO -->
  <section class="categoria-hero">
    <div class="container">
      <nav aria-label="Ruta de navegación" style="margin-bottom:1rem;">
        <ol class="breadcrumb-arms">
          <li><a href="/">Inicio</a></li>
          <li><span aria-hidden="true">›</span></li>
          <li><a href="/audio/">Audio</a></li>
          <li><span aria-hidden="true">›</span></li>
          <li aria-current="page">Interfaces</li>
        </ol>
      </nav>
      <div class="categoria-hero-inner">
        <div>
          <h1 class="categoria-titulo">Interfaces de Audio</h1>
          <p class="categoria-subtitulo">Interfaces profesionales para grabación, mezcla y producción musical</p>
        </div>
        <div class="categoria-stats">
          <span class="categoria-count">{{ productos["audio-interfaces"] | length }} productos</span>
        </div>
      </div>
      <a href="/audio/" class="categoria-banner-accesorio">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        <span>Ver todo <strong>Audio Profesional</strong></span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
  </section>

  <!-- DESCRIPCIÓN -->
  <section style="padding-bottom:1.5rem;">
    <div class="container">
      <p style="color:rgba(255,255,255,0.5); font-size:0.95rem; max-width:680px; line-height:1.7;">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident.
      </p>
    </div>
  </section>

  <!-- GRID -->
  <section class="categoria-grid-section">
    <div class="container">

      <div class="row g-3" id="row-categoria-audio-interfaces">
        {% for prod in productos["audio-interfaces"] %}
        {% set varId  = ("var-cat-" + prod.nombre) | replace(" ", "-") | replace("/", "-") %}
        {% set btnId  = ("btn-cat-" + prod.nombre) | replace(" ", "-") | replace("/", "-") %}
        {% set prodUrl = prod.id | productoUrl %}
        <div class="col-6 col-lg-3">
            {% include "card-producto.njk" %}
        </div>
        {% endfor %}
      </div>

    </div>
  </section>

</div>
