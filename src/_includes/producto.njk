{# Todos los datos vienen del objeto prod (pagination alias) #}
{% set nombre        = prod.nombre %}
{% set precio        = prod.precio %}
{% set precioOriginal= prod.precioOriginal %}
{% set descuento     = prod.descuento %}
{% set g1            = prod.g1 %}
{% set g2            = prod.g2 %}
{% set svgTipo       = prod.svgTipo %}
{% set variantes     = prod.variantes %}
{% set subtitulo     = prod.subtitulo %}
{% set descripcion   = prod.descripcion %}
{% set seccion       = prod.seccion %}
{% set pilar         = prod.pilar %}
{% set relacionados  = prod.relacionados %}
{% set imagenes      = prod.imagenes %}
{% set imagenesVariantes = prod.imagenesVariantes %}

{# Pilar label y URL #}
{% if pilar == "in-ears" %}
  {% set pilarLabel = "In-Ears" %}
  {% set pilarUrl   = "/in-ears/" %}
{% elif pilar == "in-ears/accesorios" %}
  {% set pilarLabel = "Accesorios In-Ears" %}
  {% set pilarUrl   = "/in-ears/accesorios/" %}
{% elif pilar == "audio/sistemas" %}
  {% set pilarLabel = "Sistemas" %}
  {% set pilarUrl   = "/audio/sistemas/" %}
{% elif pilar == "audio/interfaces" %}
  {% set pilarLabel = "Interfaces" %}
  {% set pilarUrl   = "/audio/interfaces/" %}
{% elif pilar == "audio/microfonos" %}
  {% set pilarLabel = "Micrófonos" %}
  {% set pilarUrl   = "/audio/microfonos/" %}
{% elif pilar == "audio/cables" %}
  {% set pilarLabel = "Cables" %}
  {% set pilarUrl   = "/audio/cables/" %}
{% else %}
  {% set pilarLabel = "Audio" %}
  {% set pilarUrl   = "/audio/" %}
{% endif %}

{% set varId = ("var-" + nombre) | replace(" ", "-") | replace("/", "-") %}
{% set btnId = ("btn-add-" + nombre) | replace(" ", "-") | replace("/", "-") %}

<div class="producto-page">

  <!-- BREADCRUMB -->
  <section class="pt-producto pb-0">
    <div class="container">
      <nav aria-label="Ruta de navegación" style="margin-bottom:1.5rem;">
        <ol class="breadcrumb-arms">
          <li><a href="/">Inicio</a></li>
          <li><span aria-hidden="true">›</span></li>
          <li><a href="{{ pilarUrl }}">{{ pilarLabel }}</a></li>
          <li><span aria-hidden="true">›</span></li>
          <li aria-current="page">{{ nombre }}</li>
        </ol>
      </nav>
    </div>
  </section>

  <!-- HERO DEL PRODUCTO -->
  <section class="pt-0 pb-producto">
    <div class="container">
      <div class="row g-4 g-lg-5 align-items-start">

        <!-- Galería -->
        <div class="col-lg-5">
          {% include "product-gallery.njk" %}

          {% if descuento %}
          <div class="text-center mt-3">
            <span class="badge-discount-lg">🔥 {{ descuento }} de descuento</span>
          </div>
          {% endif %}
        </div>

        <!-- Info -->
        <div class="col-lg-7">

          <h1 class="producto-nombre">{{ nombre }}</h1>
          {% if subtitulo %}<p class="producto-subtitulo">{{ subtitulo }}</p>{% endif %}

          <div class="producto-precio-wrap">
            {% if precioOriginal %}
            <span class="producto-precio-original">{{ precioOriginal | gtq }}</span>
            {% endif %}
            <span class="producto-precio-actual">{{ precio | gtq }}</span>
          </div>

          <div class="stock-indicator" style="margin-bottom:1.25rem;"></div>

          {% if variantes %}
          <div class="mb-4">
            <p class="producto-label-variante">Color / Versión</p>
            <div class="d-flex flex-wrap gap-2" id="{{ varId }}">
              {% for varName in variantes %}
              <button
                onclick="seleccionarVariante(this, '{{ nombre }}', '{{ varName }}', {{ precio }})"
                data-img="/assets/img/productos/{{ imagenesVariantes[varName] if imagenesVariantes[varName] else imagenes[0] }}"
                style="padding:0.35rem 0.85rem; border-radius:0.5rem; font-size:0.82rem; font-weight:600; cursor:pointer; {{ vs[varName] }}; transition:all .15s ease;"
                {% if loop.first %}class="var-btn-active"{% endif %}>
                {{ varName }}
              </button>
              {% endfor %}
            </div>
          </div>
          {% endif %}

          <div class="producto-acciones">
            {% if variantes %}
            <button
              class="btn btn-agregar btn-agregar-lg"
              id="{{ btnId }}"
              data-product-name="{{ nombre }} - {{ variantes[0] }}"
              data-img="/assets/img/productos/{{ imagenesVariantes[variantes[0]] if imagenesVariantes[variantes[0]] else imagenes[0] }}"
              onclick="agregarAlCarrito('{{ nombre }} - {{ variantes[0] }}', {{ precio }}, this)">
              <i class="fa-solid fa-cart-plus"></i> Agregar al carrito
            </button>
            {% else %}
            <button
              class="btn btn-agregar btn-agregar-lg"
              data-product-name="{{ nombre }}"
              data-img="/assets/img/productos/{{ imagenes[0] }}"
              onclick="agregarAlCarrito('{{ nombre }}', {{ precio }}, this)">
              <i class="fa-solid fa-cart-plus"></i> Agregar al carrito
            </button>
            {% endif %}
            <a href="https://wa.me/50234646667?text=Hola%2C%20me%20interesa%3A%20{{ nombre | urlencode }}%20(Q{{ precio }})"
              target="_blank" rel="noopener noreferrer"
              class="btn btn-whatsapp-producto">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Consultar por WhatsApp
            </a>
          </div>

          <div class="producto-chips">
            <span class="chip"><i class="fa-solid fa-truck chip-icon"></i> Envío a toda Guatemala</span>
            <span class="chip"><i class="fa-solid fa-shield-halved chip-icon"></i> Garantía incluida</span>
            <span class="chip"><i class="fa-solid fa-rotate-left chip-icon"></i> Cambios y devoluciones</span>
          </div>

        </div>
      </div>
    </div>
  </section>

  {% if descripcion %}
  <section class="py-producto-sm">
    <div class="container">
      <div class="producto-descripcion-card">
        <h2 class="producto-section-title">Descripción</h2>
        <p class="producto-descripcion-texto">{{ descripcion | safe }}</p>
      </div>
    </div>
  </section>
  {% endif %}

  {% if relacionados and relacionados.length > 0 %}
  <section class="py-producto-sm">
    <div class="container">
      <h2 class="producto-section-title mb-4">También te puede interesar</h2>
      <div class="row g-3">
        {% for rel in relacionados %}
        {% set relVarId = ("var-cat-" + rel.nombre) | replace(" ", "-") | replace("/", "-") %}
        {% set relBtnId = ("btn-cat-" + rel.nombre) | replace(" ", "-") | replace("/", "-") %}
        {% set relUrl   = rel.id | productoUrl %}
        <div class="col-6 col-lg-3">
            {% set prod    = rel %}
            {% set prodUrl = rel.id | productoUrl %}
            {% set varId   = ("var-cat-" + rel.nombre) | replace(" ", "-") | replace("/", "-") %}
            {% set btnId   = ("btn-cat-" + rel.nombre) | replace(" ", "-") | replace("/", "-") %}
            {% include "card-producto.njk" %}
        </div>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  <section class="py-producto-sm">
    <div class="container">
      <a href="{{ pilarUrl }}" class="btn-volver">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Volver a {{ pilarLabel }}
      </a>
    </div>
  </section>

</div>

<script>
function cambiarImagen(src, btn) {
  document.getElementById('img-principal').src = src;
  document.querySelectorAll('.thumb-btn').forEach(b => {
    b.style.borderColor = 'rgba(255,255,255,0.12)';
    b.classList.remove('thumb-active');
  });
  btn.style.borderColor = 'var(--bs-primary)';
  btn.classList.add('thumb-active');
}
</script>
