{% set svgPartial = "svgs/" + svgTipo + ".njk" %}

{% if imagenes and imagenes.length > 0 %}

  <div class="producto-imagen-wrap" id="img-principal-wrap"
    style="background:linear-gradient(135deg,{{ g1 }},{{ g2 }}); overflow:hidden; position:relative; touch-action:pan-y;">

    <div id="img-track" style="display:flex; width:100%; height:100%; will-change:transform;">
      {% for img in imagenes %}
      <div style="min-width:100%; height:100%; flex-shrink:0;">
        <img src="/assets/img/productos/{{ img }}"
          alt="{{ nombre }} foto {{ loop.index }}"
          onerror="this.style.display='none'"
          style="width:100%; height:100%; object-fit:contain; display:block; pointer-events:none;">
      </div>
      {% endfor %}
    </div>

    <template id="svg-tmpl-main">{% include svgPartial %}</template>
  </div>

  {% if imagenes.length > 1 %}
  <div style="display:flex; gap:0.5rem; margin-top:0.75rem; flex-wrap:wrap;">
    {% for img in imagenes %}
    <button
      style="width:64px; height:64px; border-radius:0.5rem; overflow:hidden; padding:0; cursor:pointer;
             border:2px solid {% if loop.first %}var(--bs-primary){% else %}rgba(255,255,255,0.12){% endif %};
             background:linear-gradient(135deg,{{ g1 }},{{ g2 }});
             transition:border-color .15s ease; flex-shrink:0;"
      class="thumb-btn {% if loop.first %}thumb-active{% endif %}"
      data-index="{{ loop.index0 }}">
      <img src="/assets/img/productos/{{ img }}" alt="{{ nombre }} foto {{ loop.index }}"
        style="width:100%; height:100%; object-fit:contain; pointer-events:none;">
    </button>
    {% endfor %}
  </div>
  {% endif %}

  <script>
  (function() {
    const wrap   = document.getElementById('img-principal-wrap');
    const track  = document.getElementById('img-track');
    const thumbs = document.querySelectorAll('.thumb-btn');
    const total  = {{ imagenes | length }};
    if (!wrap || !track || total <= 1) return;

    let idx      = 0;
    let startX   = 0;
    let startY   = 0;
    let diffX    = 0;
    let active   = false;
    let isH      = null;
    let blocked  = false; // true cuando el gesto tocó un límite

    // Posicionar track sin animación
    function setPos(i) {
      track.style.transition = 'none';
      track.style.transform  = `translateX(-${i * 100}%)`;
    }

    // Ir a imagen con animación
    function goTo(i, animate) {
      idx = Math.max(0, Math.min(i, total - 1));
      track.style.transition = animate ? 'transform 0.28s cubic-bezier(.4,0,.2,1)' : 'none';
      track.style.transform  = `translateX(-${idx * 100}%)`;
      // Resetear scaleX de la imagen actual
      const imgs = track.querySelectorAll('div > img');
      imgs.forEach(im => { im.style.transform = ''; im.style.transformOrigin = ''; });
      // Actualizar thumbnails
      thumbs.forEach((t, ti) => {
        t.style.borderColor = ti === idx ? 'var(--bs-primary)' : 'rgba(255,255,255,0.12)';
        t.classList.toggle('thumb-active', ti === idx);
      });
    }

    // Obtener imagen visible actual
    function imgActual() {
      const divs = track.querySelectorAll('div');
      return divs[idx] ? divs[idx].querySelector('img') : null;
    }

    wrap.addEventListener('touchstart', function(e) {
      startX  = e.touches[0].clientX;
      startY  = e.touches[0].clientY;
      diffX   = 0;
      active  = true;
      isH     = null;
      blocked = false;
      track.style.transition = 'none';
    }, { passive: true });

    wrap.addEventListener('touchmove', function(e) {
      if (!active) return;
      const dx = e.touches[0].clientX - startX;
      const dy = e.touches[0].clientY - startY;

      // Detectar dirección una sola vez
      if (isH === null) {
        if (Math.abs(dx) < 5 && Math.abs(dy) < 5) return;
        isH = Math.abs(dx) >= Math.abs(dy);
      }
      if (!isH) return;

      const enInicio = dx > 0 && idx === 0;
      const enFinal  = dx < 0 && idx === total - 1;

      if (enInicio || enFinal) {
        // Bloquear el gesto completo
        blocked = true;
        diffX   = 0;
        // Rubber band: scaleX solo en la imagen visible, track fijo
        const img = imgActual();
        if (img) {
          const r = Math.abs(dx) / wrap.offsetWidth;
          const s = 1 + Math.min(r * 0.06, 0.04);
          img.style.transformOrigin = enInicio ? '0% 50%' : '100% 50%';
          img.style.transform = `scaleX(${s})`;
        }
        track.style.transform = `translateX(-${idx * 100}%)`;
      } else if (!blocked) {
        // Movimiento normal solo si no bloqueado
        diffX = dx;
        const offset = -(idx * 100) + (dx / wrap.offsetWidth * 100);
        track.style.transform = `translateX(${offset}%)`;
        // Asegurar que no quede scaleX residual
        const img = imgActual();
        if (img) img.style.transform = '';
      }
    }, { passive: true });

    wrap.addEventListener('touchend', function() {
      if (!active || !isH) { active = false; return; }
      active = false;

      if (!blocked && diffX < -50 && idx < total - 1) {
        goTo(idx + 1, true);
      } else if (!blocked && diffX > 50 && idx > 0) {
        goTo(idx - 1, true);
      } else {
        goTo(idx, true);
      }
    }, { passive: true });

    // Thumbnails
    thumbs.forEach((btn, i) => {
      btn.addEventListener('click', () => goTo(i, true));
    });

    goTo(0, false);
  })();
  </script>

{% else %}

  <div class="producto-imagen-wrap" style="background:linear-gradient(135deg,{{ g1 }},{{ g2 }});">
    {% include svgPartial %}
  </div>

{% endif %}
