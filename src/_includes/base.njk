            <li class="nav-item dropdown">
              <button class="nav-link dropdown-toggle text-body" data-bs-toggle="dropdown" type="button">
                <span class="d-inline-flex align-items-center"><span>Productos</span></span>
              </button>
              <ul class="dropdown-menu">
                <li><a class="dropdown-item text-body" href="/in-ears/">In Ears</a></li>
                <li><a class="dropdown-item text-body" href="/audio/sistemas/">Monitoreo</a></li>
                <li><a class="dropdown-item text-body" href="/audio/">Audio y Accesorios</a></li>
                <li><a class="dropdown-item text-body" href="/in-ears/accesorios/">Accesorios In Ears</a></li>
              </ul>
            </li>
            <li class="nav-item"><a class="nav-link text-body" href="#inears">Categorías</a></li>
            <li class="nav-item"><a class="nav-link text-body" href="#contacto">Contacto</a></li>

          </ul>

          <!-- Desktop: search + carrito -->
          <div class="d-none d-lg-inline-flex align-items-center gap-2">
            <div class="navbar-search-wrap" id="navbar-search-wrap-desktop">
              <button id="navbar-search-btn" aria-label="Buscar productos">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              </button>
              <input id="search-input" type="search" placeholder="Buscar producto..." autocomplete="off" autocorrect="off" spellcheck="false" aria-label="Buscar productos" />
              <button id="search-clear" aria-label="Limpiar búsqueda" title="Limpiar">✕</button>
            </div>
            <!-- Carrito desktop -->
            <button onclick="abrirCarrito()" aria-label="Ver carrito" style="position:relative; background:var(--bs-primary); border:none; border-radius:0.75rem; width:40px; height:40px; display:flex; align-items:center; justify-content:center; cursor:pointer; color:#fff; box-shadow:0 4px 14px rgba(102,0,255,0.45); transition:all .2s ease;"
              onmouseover="this.style.background='#7c74ff'; this.style.boxShadow='0 6px 20px rgba(102,0,255,0.6)'"
              onmouseout="this.style.background='var(--bs-primary)'; this.style.boxShadow='0 4px 14px rgba(102,0,255,0.45)'">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              <span id="cart-count-desktop" style="display:none; position:absolute; top:-6px; right:-6px; background:#ef4444; color:#fff; border-radius:50%; width:18px; height:18px; font-size:10px; font-weight:700; align-items:center; justify-content:center;">0</span>
            </button>
          </div>
        </div>

      </nav>
    </div>
  </header>

  <!-- ============================================================
       PANEL DE BÚSQUEDA
  ============================================================ -->
  <div id="search-panel" aria-label="Buscar productos" style="display:none; position:fixed; top:0; left:0; right:0; z-index:1028; padding-top:80px;">
    <div style="background:rgba(14,13,20,0.97); backdrop-filter:blur(28px) saturate(180%); -webkit-backdrop-filter:blur(28px) saturate(180%); border-bottom:1px solid rgba(139,120,255,0.18); box-shadow:0 8px 32px rgba(0,0,0,0.55); padding:0.75rem 0 0.85rem;">
      <div class="container">
        <div style="position:relative;">
          <svg style="position:absolute;left:0.75rem;top:50%;transform:translateY(-50%);color:rgba(255,255,255,0.35);pointer-events:none;" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="search-input-panel" type="search" placeholder="Buscar producto..." autocomplete="off" autocorrect="off" spellcheck="false" aria-label="Buscar productos" style="width:100%; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.12); border-radius:2rem; padding:0.5rem 2.2rem 0.5rem 2.3rem; color:#fff; font-family:'Lexend',sans-serif; font-size:0.9rem; outline:none; -webkit-appearance:none; transition:border-color .2s, box-shadow .2s;" />
          <button id="search-clear-panel" aria-label="Limpiar" style="position:absolute;right:0.55rem;top:50%;transform:translateY(-50%);display:none;background:rgba(255,255,255,0.14);border:none;border-radius:50%;width:18px;height:18px;align-items:center;justify-content:center;cursor:pointer;color:rgba(255,255,255,0.7);font-size:9px;padding:0;">✕</button>
        </div>
        <!-- Autocomplete dropdown -->
        <div id="search-dropdown" style="display:none; margin-top:0.5rem; max-height:60vh; overflow-y:auto; border-radius:0.75rem; border:1px solid rgba(139,120,255,0.18); background:rgba(22,21,30,0.98);"></div>
      </div>
    </div>
  </div>

  <!-- ============================================================
       CONTENIDO PRINCIPAL
  ============================================================ -->
  <main id="main-content">
    {{ content | safe }}
  </main>

