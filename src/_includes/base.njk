<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
  <!-- META BASE -->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, shrink-to-fit=no" />
  <meta name="HandheldFriendly" content="True" />
  <meta name="MobileOptimized" content="320" />
  <meta name="author" content="{{ site.nombre }}" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />

  <!-- TÍTULO SEO -->
  <!-- seoTitulo: definido en el frontmatter de cada página para control total -->
  <!-- Fallback: "Titulo de página | ARMS Music"                               -->
  <title>{{ seoTitulo if seoTitulo else (titulo + " | " + site.nombre) }}</title>

  <!-- META DESCRIPTION -->
  <!-- seoDescripcion: definido por página. Sin esto Google inventa la descripción -->
  <meta name="description" content="{{ seoDescripcion if seoDescripcion else site.descripcion }}" />

  <!-- ROBOTS -->
  <!-- DESARROLLO: noindex activo. Cambiar a 'index, follow' el día del launch -->
  <meta name="robots" content="{{ robots if robots else 'noindex, nofollow' }}" />

  <!-- CANONICAL -->
  <!-- Evita contenido duplicado si la página es accesible por múltiples URLs -->
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />

  <!-- OPEN GRAPH — controla cómo se ve el link en WhatsApp, Facebook, etc. -->
  <meta property="og:type" content="{{ ogType if ogType else 'website' }}" />
  <meta property="og:title" content="{{ seoTitulo if seoTitulo else titulo }}" />
  <meta property="og:description" content="{{ seoDescripcion if seoDescripcion else site.descripcion }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:image" content="{{ site.url }}{{ ogImagen if ogImagen else site.imagenDefault }}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="{{ site.nombre }}" />
  <meta property="og:locale" content="es_GT" />

  <!-- TWITTER CARD -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ seoTitulo if seoTitulo else titulo }}" />
  <meta name="twitter:description" content="{{ seoDescripcion if seoDescripcion else site.descripcion }}" />
  <meta name="twitter:image" content="{{ site.url }}{{ ogImagen if ogImagen else site.imagenDefault }}" />

  <!-- STRUCTURED DATA (Schema.org JSON-LD) -->
  <!-- Cada página define schemaJson en su frontmatter. Base.njk lo imprime si existe. -->
  {% if schemaJson %}
  <script type="application/ld+json">{{ schemaJson | safe }}</script>
  {% endif %}

  <!-- FAVICON -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/favicon.svg" />

  <!-- FUENTES -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700;800;900&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />

  <!-- BOOTSTRAP 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

  <!-- ESTILOS PROPIOS -->
  <link rel="stylesheet" href="/assets/css/main.css" />
  <link rel="stylesheet" href="/assets/css/producto.css" />
  <link rel="stylesheet" href="/assets/css/categoria.css" />
</head>

<body>

  <!-- ============================================================
       NAVBAR
  ============================================================ -->
  <header>
    <div class="navbar-wrapper">
      <nav class="navbar navbar-expand-lg navbar-floating" aria-label="Navegación principal">

