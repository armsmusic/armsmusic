        <!-- Mobile: lupa + hamburger -->
        <div class="d-lg-none d-flex align-items-center ms-auto gap-2">
          <button id="navbar-search-btn-mobile" aria-label="Buscar" style="
            background:none; border:none; color:rgba(255,255,255,0.6);
            cursor:pointer; padding:0.35rem; border-radius:0.5rem;
